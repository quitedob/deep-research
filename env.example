# 深度研究平台环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ===== 应用基础配置 =====
APP_NAME=Deep Research Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
ENABLE_RELOAD=true

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://deepresearch:deepresearch_password@localhost:5432/deepresearch_db

# ===== Redis配置 =====
REDIS_URL=redis://localhost:6379

# ===== JWT配置 =====
SECRET_KEY=your_super_secret_jwt_key_here_make_it_long_and_random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Stripe配置 =====
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_price_id_here
FRONTEND_URL=http://localhost:3000

# ===== 配额配置 =====
FREE_TIER_LIFETIME_LIMIT=5
SUBSCRIBED_TIER_HOURLY_LIMIT=5
QUOTA_WINDOW_SIZE=3600

# ===== 文件上传配置 =====
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.docx,.doc,.txt,.md,.pdf
UPLOAD_DIR=./uploads
TEMP_DIR=./temp

# ===== RAG配置 =====
RAG_INDEX_PATH=./data/rag_documents
VECTOR_STORE_PATH=./data/vector_store
VECTOR_DIMENSION=1536

# ===== 任务队列配置 =====
TASK_QUEUE_TYPE=redis
TASK_QUEUE_URL=redis://localhost:6379
MAX_WORKERS=4
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=300

# ===== 缓存配置 =====
ENABLE_CACHING=true
CACHE_TTL=1800

# ===== 日志配置 =====
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true

# ===== CORS配置 =====
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
ENABLE_CORS_DEBUG=false

# ===== 健康检查配置 =====
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL=300
HEALTH_CHECK_TIMEOUT=10

# ===== 数据库表自动创建（开发环境） =====
AUTO_CREATE_TABLES=true

# ===== LLM配置 =====
LLM_PROVIDER=api
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# ===== 对话记忆配置 =====
ENABLE_CONVERSATION_MEMORY=true
MEMORY_MAX_TOKENS=4000
MEMORY_TTL_HOURS=24 